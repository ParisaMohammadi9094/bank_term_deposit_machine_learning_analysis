from sklearn.metrics import confusion_matrix

def print_confusion_report(y_test, y_pred):
    cm = confusion_matrix(y_test, y_pred)
    TN, FP, FN, TP = cm.ravel()

    recall_no = TN / (TN + FP) * 100
    recall_yes = TP / (TP + FN) * 100

    print(f"Out of {TN + FP} actual 'No' samples:")
    print(f"  - {recall_no:.1f}% correctly predicted as 'No' ({TN} samples)")
    print(f"  - {100 - recall_no:.1f}% incorrectly predicted as 'Yes' ({FP} samples)")
    print()
    print(f"Out of {TP + FN} actual 'Yes' samples:")
    print(f"  - {recall_yes:.1f}% correctly predicted as 'Yes' ({TP} samples)")
    print(f"  - {100 - recall_yes:.1f}% incorrectly predicted as 'No' ({FN} samples) ← Main problem!")

# Usage:
print_confusion_report(y_test, y_pred)
